{
  "layer": "overlay",
  "position": "top",
  "exclusive": false,
  "margin-bottom": 6,
  "margin-right": 0,
  "modules-right": [
    "battery",
    "clock"
  ],
  "battery": {
    "format": "{capacity}% {icon}",
    "format-charging": "яГз {capacity}%",
    "format-icons": [
      "яЙД",
      "яЙГ",
      "яЙВ",
      "яЙБ",
      "яЙА"
    ],
    "states": {
      "warning": 30,
      "critical": 15
    }
  },
  "clock": {
    "format": "{:%m:%d:%H:%M}"
  }
}
